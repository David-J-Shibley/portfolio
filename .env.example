# Featherless.ai (server-only ‚Äî never prefix with VITE_)
# Used by `npm run dev`, Docker/EC2 (`npm start` / `docker compose`), and Vercel `api/chat`.
FEATHERLESS_API_KEY=

# Optional; default is Qwen/Qwen2.5-7B-Instruct
# FEATHERLESS_MODEL=Qwen/Qwen2.5-7B-Instruct

# Production server / container listen port (default 8080)
# PORT=8080

# Public site origin for Open Graph / canonical URLs (no trailing slash), e.g. https://yoursite.com
# VITE_SITE_ORIGIN=https://example.com

# Chat API rate limit (per IP, in-memory; optional)
# CHAT_RATE_LIMIT_MAX=24
# CHAT_RATE_LIMIT_WINDOW_MS=60000
